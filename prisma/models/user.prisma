model User {
  id            String          @id @default(uuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  preferences   Json            @default("{}")
  accounts      Account[]
  sessions      Session[]
  // Optional for WebAuthn support
  Authenticator Authenticator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems              OrderItem[]
  orderWorkflowsAssigned  OrderWorkflow[] @relation("OrderWorkflowAssignedTo")
  orderWorkflowsPacked    OrderWorkflow[] @relation("OrderWorkflowPackedBy")
  orderWorkflowsQA        OrderWorkflow[] @relation("OrderWorkflowQABy")
  notes                   Note[]
  qualityIssuesReported   QualityIssue[] @relation("QualityIssueReportedBy")
  qualityIssuesResponsible QualityIssue[] @relation("QualityIssueResponsible")
  qualityIssuesResolved   QualityIssue[] @relation("QualityIssueResolvedBy")
  orderItemsVoided        OrderItem[]    @relation("OrderItemVoidedBy")
  orderVoidsResolved      OrderVoid[]    @relation("OrderVoidResolvedBy")
}
